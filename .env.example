# Required
PAYER_KEYPAIR=/absolute/path/to/payer.json
RPC_URL=https://api.mainnet-beta.solana.com
WSS_URL=wss://api.mainnet-beta.solana.com

# Optional Telegram alerts
TG_BOT_API_TOKEN=
TG_CHAT_ID=

# Safety: SIM-only by default in this repo
ARB_SIM_ONLY=true

# Pool source mode
# false => only cfg.toml pools
# true  => also onboard cross-venue candidates from listener DB
ARB_DYNAMIC_DB_ENABLED=false
ARB_LISTENER_DB_PATH=/path/to/sol_pool_listener/data/pools.db
ARB_DYNAMIC_DB_POLL_SECS=8

# Optional: keep dynamically discovered routes simulation-only even if ARB_SIM_ONLY=false
ARB_DYNAMIC_SIM_ONLY=true
